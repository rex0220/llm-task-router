{
  "permissions": {
    "allow": [
      "Bash(llm-task-router article:create:*)",
      "Bash(llm-task-router article:refine:*)",
      "Bash(llm-task-router article:evaluate:*)",
      "Bash(llm-task-router article:revise:*)",
      "Bash(llm-task-router article:resume:*)",
      "Bash(llm-task-router article:review:*)",
      "Bash(llm-task-router article:import:*)",
      "Bash(llm-task-router article:update-diff:*)",
      "Bash(llm-task-router article:claims-normalize:*)",
      "Bash(llm-task-router article:claims-recheck:*)",
      "Bash(llm-task-router article:verify-artifacts:*)",
      "Bash(llm-task-router article:review-editorial:*)",
      "Bash(llm-task-router article:status:*)",
      "Bash(llm-task-router article:progress:event:*)",
      "Bash(llm-task-router article:completion-report:*)",
      "Bash(llm-task-router article:direction-check:*)",
      "Bash(llm-task-router article:factcheck-scope:*)",
      "Bash(llm-task-router article:references:*)",
      "Bash(llm-task-router article:factcheck-stamp:*)",
      "Bash(llm-task-router article:export:*)",
      "Bash(llm-task-router article:record-publication:*)",
      "Bash(llm-task-router --help)",
      "Bash(llm-task-router -v)",
      "WebSearch",
      "WebFetch"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/auto-approve-llm-task-router.mjs\"",
            "statusMessage": "記事ワークフローのコマンドを判定中"
          }
        ]
      }
    ]
  }
}
