{
  "permissions": {
    "allow": [
      "Bash(llm-task-router article:*)",
      "Bash(llm-task-router series:init:*)",
      "Bash(llm-task-router series:freeze-voice:*)",
      "Bash(llm-task-router series:status:*)",
      "Bash(llm-task-router --help)",
      "Bash(llm-task-router -v)",
      "WebSearch",
      "WebFetch"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/auto-approve-llm-task-router.mjs\"",
            "statusMessage": "記事ワークフローのコマンドを判定中"
          }
        ]
      }
    ]
  }
}
